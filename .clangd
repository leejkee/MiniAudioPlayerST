---
# 当 compile_commands.json 中未包含某个文件时, clangd 使用以下配置作为兜底。
# 正常情况下, 运行 .\generate_compile_commands.ps1 后所有源文件都会被收录,
# 以下 CompileFlags 仅在未运行脚本或新增文件尚未收录时生效。

CompileFlags:
  Add:
    # ARM Cortex-M0 目标架构 (STM32F072xB)
    - "--target=arm-none-eabi"
    - "-mcpu=cortex-m0"
    - "-mfloat-abi=soft"
    - "-mthumb"
    # HAL 驱动头文件
    - "-I firmware/MiniAudioPlayerST/Core/Inc"
    - "-I firmware/MiniAudioPlayerST/Drivers/STM32F0xx_HAL_Driver/Inc"
    - "-I firmware/MiniAudioPlayerST/Drivers/STM32F0xx_HAL_Driver/Inc/Legacy"
    - "-I firmware/MiniAudioPlayerST/Drivers/CMSIS/Device/ST/STM32F0xx/Include"
    - "-I firmware/MiniAudioPlayerST/Drivers/CMSIS/Include"
    # 业务层头文件
    - "-I firmware/MiniAudioPlayerST/App/include"
    - "-I firmware/MiniAudioPlayerST/BSP/include"
    # CubeMX 预设宏
    - "-D USE_HAL_DRIVER"
    - "-D STM32F072xB"

Diagnostics:
  # 抑制因缺少 ARM GCC 标准库头文件 (如 <stdint.h>) 导致的误报
  # 不影响代码导航和补全功能
  Suppress:
    - "pp_file_not_found"
  UnusedIncludes: None
